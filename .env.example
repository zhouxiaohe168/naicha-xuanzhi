# 数据库
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/naicha_xuanzhi

# JWT密钥（生产环境必须更换）
SECRET_KEY=change-this-to-a-random-string

# 高德地图API
AMAP_KEY=your-amap-key

# OpenRouter API（AI研判，支持 Claude/GPT/Gemini 等多种模型）
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=anthropic/claude-3-haiku

# 阿里云短信
SMS_ACCESS_KEY_ID=your-access-key-id
SMS_ACCESS_KEY_SECRET=your-access-key-secret
SMS_SIGN_NAME=奶茶选址通
SMS_TEMPLATE_CODE=your-template-code

# 微信支付
WECHAT_MCH_ID=your-mch-id
WECHAT_API_KEY=your-api-key

# 支付宝
ALIPAY_APP_ID=your-app-id
ALIPAY_PRIVATE_KEY=your-private-key
